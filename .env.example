# Copy to .env and fill in values (never commit .env)
# Keys referenced in config/config.yaml via ${VAR_NAME}

OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Optional: override config and data paths
# PARWRITE_CONFIG=/path/to/config.yaml
# PARWRITE_DATA_DIR=/path/to/data

# Optional: deployment TOTP secrets (base32)
# ACCESS_TOTP_SECRET=
# RESTART_TOTP_SECRET=
