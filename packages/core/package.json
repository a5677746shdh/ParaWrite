{
  "name": "@parawrite/core",
  "version": "0.8.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "pnpm run build && node --test dist/layout.test.js dist/user-config.test.js dist/glossary.test.js dist/segmenter.test.js dist/prompts.test.js"
  },
  "dependencies": {
    "franc": "^6.2.0",
    "js-yaml": "^4.1.0",
    "lru-cache": "^11.0.2",
    "otplib": "^12.0.1",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
